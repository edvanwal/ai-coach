# Kopieer dit bestand naar .env.local en vul je keys in
# Voor cloud-deployment (Neon/PostgreSQL) zie docs/DEPLOYMENT.md

# Voor Neon/PostgreSQL, voorbeeld-URL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

DATABASE_URL=
CRON_SECRET=       # Verplicht bij cloud-hosting (herinneringen)

OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-5
OPENAI_CHAT_FALLBACK_MODEL=gpt-4.1
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
# Spreeksnelheid 0.25–4.0 (default 1.0), bijv. 1.2 voor iets sneller
OPENAI_TTS_SPEED=1.2

# TTS-provider: openai (default) of elevenlabs
# TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=...   # zie elevenlabs.io voor voice-IDs
# ELEVENLABS_MODEL=eleven_turbo_v2_5   # of eleven_flash_v2_5 voor lage latentie
# ELEVENLABS_SPEED=1.0      # 0.5–2.0

# Pushover (iPhone-notificatie als de AI klaar is)
PUSHOVER_TOKEN=
PUSHOVER_USER=

